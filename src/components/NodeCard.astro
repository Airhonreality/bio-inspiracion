---
interface Props {
	title: string;
	description: string;
	tag: string;
	color: string;
}

const { title, description, tag, color } = Astro.props;
---

<div class="node-card" style={`--node-color: ${color}`}>
	<div class="node-badge">{tag}</div>
	<h3>{title}</h3>
	<p>{description}</p>
	<div class="node-link">Explorar Repositorio →</div>
</div>

<style>
	.node-card {
		background: white;
		padding: 3rem 2rem;
		border-radius: var(--radius-petal);
		border: 1px solid rgba(0,0,0,0.05);
		transition: all 0.5s var(--transition-blossom);
		position: relative;
		cursor: pointer;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.node-card:hover {
		transform: translateY(-10px);
		background-color: var(--node-color);
		color: white;
	}

	.node-card:hover h3, 
	.node-card:hover .node-badge, 
	.node-card:hover .node-link {
		color: white;
	}

	h3 {
		font-family: var(--font-serif);
		font-size: 1.8rem;
		margin: 0.5rem 0;
		color: var(--color-sombra-barro);
		transition: color 0.3s ease;
	}

	p {
		font-size: 1rem;
		opacity: 0.9;
		margin: 1rem 0;
	}

	.node-badge {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--node-color);
		font-weight: 700;
	}

	.node-link {
		margin-top: 2rem;
		font-size: 0.8rem;
		font-weight: bold;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-suelo-canela);
	}
</style>

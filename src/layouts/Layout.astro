---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Montechico - Repositorio de Investigación Premium" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="pistil-track"></div>
		<main>
			<slot />
		</main>
		<style is:global>
			@import '../styles/tokens.css';
			
			main {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2rem;
			}

			.organic-card {
				background-color: white;
				border-radius: var(--radius-petal);
				padding: 3rem;
				box-shadow: 0 10px 30px rgba(0,0,0,0.05);
				transition: border-radius 0.5s var(--transition-blossom);
				margin-bottom: 3rem;
				position: relative;
				overflow: hidden;
			}

			.organic-card:hover {
				border-radius: var(--radius-stone);
			}

			.organic-card::before {
				content: '';
				position: absolute;
				top: -10px;
				left: -10px;
				width: 30px;
				height: 30px;
				background-color: var(--color-suelo-canela);
				border-radius: 50%;
				opacity: 0.1;
			}
		</style>
	</body>
</html>

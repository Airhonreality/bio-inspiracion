---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map(entry => ({
		params: { slug: entry.slug }, props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.id} | Semillero`}>
	<article class="doc-container">
		<header class="doc-header">
			<a href="/" class="back-link">← Volver al mapa</a>
			<div class="category-chip">{entry.id.split('.')[0]}</div>
			<h1>{entry.id}</h1>
		</header>
		
		<section class="prose">
			<Content />
		</section>
	</article>

	<style is:global>
		.doc-container {
			max-width: 800px;
			margin: 4rem auto;
			animation: slide-up 0.8s var(--transition-blossom);
		}

		@keyframes slide-up {
			from { opacity: 0; transform: translateY(30px); }
			to { opacity: 1; transform: translateY(0); }
		}

		.doc-header {
			margin-bottom: 4rem;
			border-left: 2px solid var(--color-suelo-canela);
			padding-left: 2rem;
		}

		.back-link {
			text-transform: uppercase;
			font-size: 0.8rem;
			letter-spacing: 0.1em;
			color: var(--color-suelo-canela);
			text-decoration: none;
			display: block;
			margin-bottom: 1rem;
		}

		.category-chip {
			font-size: 0.7rem;
			background: var(--color-tierra-pisada);
			padding: 0.2rem 0.6rem;
			border-radius: 20px;
			display: inline-block;
			margin-bottom: 1rem;
		}

		/* Estilos Prose */
		.prose h2 { margin-top: 3rem; border-bottom: 1px solid #eee; padding-bottom: 1rem; }
		.prose p { margin-bottom: 1.5rem; font-size: 1.1rem; }
		.prose blockquote {
			border-left: 5px solid var(--color-suelo-canela);
			padding: 1rem 2rem;
			background: #fdfaf7;
			font-style: italic;
			margin: 2rem 0;
		}
		.prose code { background: #f4f4f4; padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; }
		.prose pre { padding: 2rem; border-radius: 12px; margin: 2rem 0; overflow-x: auto; }
	</style>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import NodeCard from '../components/NodeCard.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');

const subRepositories = [
	{
		id: 'hidrografia',
		title: 'Pistilos de Captación',
		description: 'Sistemas biomiméticos para la recolección vertical de agua lluvia.',
		tag: '#Agua',
		color: '#B4C7D0',
	},
	{
		id: 'arquitectura-suelo',
		title: 'Células de Tierra',
		description: 'Arquitectura ancestral y bioclimática en Barichara.',
		tag: '#Tierra',
		color: '#A67B5B',
	},
	{
		id: 'energia-eolica',
		title: 'Flujos Babilónicos',
		description: 'Captación de energía mediante membranas en espiral.',
		tag: '#Viento',
		color: '#D4C5B0',
	}
];
---

<Layout title="Semillero">
	<header class="hero">
		<div class="bio-shape"></div>
		<h1 class="logo">BIO INSPIRACIÓN</h1>
		<p class="subtitle">semillero</p>
		<p class="tagline">Bio-arquitectura • Arte • Transdisciplinariedad</p>
		<p class="manifesto">
			Un organismo vivo de investigación en Barichara que explora la convergencia entre técnicas ancestrales y la inteligencia de la naturaleza.
		</p>
	</header>

	<section class="nodes-container">
		<div class="section-label">Nodos de Investigación (Sub-repositorios)</div>
		<div class="nodes-grid">
			{subRepositories.map(repo => (
				<NodeCard {...repo} />
			))}
		</div>
	</section>

	<section class="docs-feed">
		<div class="section-label">Flujo de Apuntes Recientes</div>
		<div class="feed-grid">
			{allDocs.map(doc => (
				<article class="organic-card">
					<span class="category">{doc.id.split('.')[0]}</span>
					<h2>{doc.data.title || doc.id}</h2>
					<div class="excerpt">
						<p>Fragmentos de la bitácora de investigación en campo.</p>
					</div>
					<a href={`${import.meta.env.BASE_URL}docs/${doc.id}`} class="read-more">Explorar nodo</a>
				</article>
			))}
		</div>
	</section>

	<style>
		/* Estilos específicos de esta página (Hero y Grid) */
		.hero { padding: 10rem 0 6rem 0; text-align: center; position: relative; }
		.logo { font-size: 6rem; letter-spacing: -0.05em; color: var(--color-sombra-barro); margin: 0; text-transform: uppercase; line-height: 1; }
		.subtitle { font-size: 1.2rem; letter-spacing: 0.4em; color: var(--color-suelo-canela); margin-top: 0.5rem; text-transform: lowercase; font-weight: 300; opacity: 0.8; }
		.tagline { font-size: 0.8rem; color: var(--color-suelo-canela); letter-spacing: 0.3em; text-transform: uppercase; margin-top: 1.5rem; opacity: 0.6; }
		.manifesto { max-width: 600px; margin: 2rem auto; font-size: 1.1rem; font-style: italic; color: #666; line-height: 1.8; }
		.section-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2rem; color: var(--color-suelo-canela); margin-bottom: 2rem; text-align: center; opacity: 0.7; }
		.nodes-container { padding: 4rem 0; }
		.nodes-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
		.docs-feed { padding: 6rem 0; background: linear-gradient(to bottom, transparent, #faf8f5); }
		.feed-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 3rem; }
		.bio-shape { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 350px; height: 350px; background-color: var(--color-tierra-pisada); border-radius: var(--radius-petal); z-index: -1; opacity: 0.5; animation: breathe 10s infinite alternate ease-in-out; }
		@keyframes breathe { 0% { border-radius: var(--radius-petal); transform: translate(-50%, -50%) scale(1); } 100% { border-radius: var(--radius-stone); transform: translate(-50%, -50%) scale(1.15); } }
	</style>
</Layout>
